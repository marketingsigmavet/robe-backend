# ─────────────────────────────────────────────────────────────
# RoBe Backend – Environment Configuration
# ─────────────────────────────────────────────────────────────
#
# Copy this file to `.env` (local dev) and fill in the values.
#
# Supported APP_ENV values:
#   local  – Developer machine (reads .env / .env.local)
#   dev    – AWS shared development
#   qa     – AWS QA / integration testing
#   uat    – AWS user-acceptance testing
#   prod   – AWS production
#
# For non-local environments, variables are typically injected
# via ECS task definitions, SSM Parameter Store, or Secrets Manager.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_ENV=local
APP_NAME=RoBe Backend
LOG_LEVEL=DEBUG
DEBUG_MODE=true

# ── Database (async SQLAlchemy) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/robe

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── JWT / Auth ────────────────────────────────────────────────
JWT_SECRET=super-secret-key-change-me-in-production

# ── CORS ──────────────────────────────────────────────────────
# JSON-encoded list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Server ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── AWS (non-local environments only) ─────────────────────────
# AWS_REGION=ap-southeast-1
# AWS_SECRET_NAME=robe/dev/app-secrets
