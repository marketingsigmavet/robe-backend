# App
APP_NAME=RoBe Backend
APP_ENV=development
LOG_LEVEL=INFO

# Database (async SQLAlchemy driver)
# Example: postgresql+asyncpg://user:password@localhost:5432/robe
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/robe

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

