# Local development configuration.
# Copy/adapt as needed; Docker Compose overrides these values via environment variables.

APP_NAME=RoBe Backend
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/robe

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

