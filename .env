# ─────────────────────────────────────────────────────────────
# LOCAL development configuration
# Copy to .env.local for personal overrides (git-ignored).
# Docker Compose overrides these values via container env vars.
# ─────────────────────────────────────────────────────────────

# Environment: local | dev | qa | uat | prod
APP_ENV=local

APP_NAME=RoBe Backend
LOG_LEVEL=DEBUG
DEBUG_MODE=true

# PostgreSQL (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/robe

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT (use a real secret in non-local environments!)
JWT_SECRET=super-secret-key-change-me-in-production

# CORS (comma-separated via pydantic list parsing)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
